# =============================================
# LOCAL DEVELOPMENT
# =============================================
# For local Postgres (e.g. Docker or native install):
DATABASE_URL=postgresql://user:pass@localhost:5432/mentoria
DIRECT_URL=postgresql://user:pass@localhost:5432/mentoria

# =============================================
# PRODUCTION (Supabase)
# =============================================
# Uncomment and replace the above with these for production:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# =============================================
# AUTH
# =============================================
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-client-id

# =============================================
# AI
# =============================================
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_API_KEY=your-openrouter-api-key
AI_MODEL=openai/gpt-5.2

# =============================================
# APPLE REVIEW (optional — leave empty to disable)
# =============================================
REVIEW_INVITE_CODE=
REVIEW_MENTEE_ID=

# =============================================
# INSTAGRAM SCRAPER (RapidAPI)
# =============================================
RAPIDAPI_KEY=your-rapidapi-key-here
RAPIDAPI_HOST=instagram-scraper-stable-api.p.rapidapi.com
RAPIDAPI_BASE_URL=https://instagram-scraper-stable-api.p.rapidapi.com

# =============================================
# STORAGE (Supabase)
# =============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=drafts
